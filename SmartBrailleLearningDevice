// --- MODE CONTROLLER ---
void activateMode(int m) {
  if (activeMode == 1 && m != 1) {
    clearBrailleSmooth();
  }


  // --- SCANNER LED LOGIC ---
  if (m == 3) {
    digitalWrite(scanLed1, HIGH);
    digitalWrite(scanLed2, HIGH);
  } else {
    digitalWrite(scanLed1, LOW);
    digitalWrite(scanLed2, LOW);
  }


  activeMode = m;
  ws.textAll("MODE:" + String(m));


  if (m == 1) {
    alphabetIndex = 0;
    learnStateStep = -1;
    ws.textAll("SAY:Learning mode");
    lastLetterTime = millis();
    Serial.println("\n--- MODE 1: STARTING ---");
  }
  else if (m == 2) {
    ws.textAll("SAY:Challenge mode");
    wordsServed = 0;
   
    // SHUFFLE THE DECK EVERY TIME GAME MODE STARTS
    shuffleWords();
   
    gameStarting = true;
    gameInitTime = millis();
  }
  else if (m == 3) {
    ws.textAll("SAY:Scan mode");
  }
}


void onEvent(AsyncWebSocket *server, AsyncWebSocketClient *client, AwsEventType type, void *arg, uint8_t *data, size_t len) {
  if (type == WS_EVT_DATA) {
    AwsFrameInfo *info = (AwsFrameInfo*)arg;
    if (info->final && info->index == 0 && info->len == len && info->opcode == WS_TEXT) {
      data[len] = 0; String message = (char*)data;
      if(message.startsWith("CHECK:")) {
        String attempt = message.substring(6);
        if(targetWordIndex != -1 && attempt == testWords[targetWordIndex]) {
          ws.textAll("CORRECT");
          delay(1000);
          startNewGame();
        } else {
          ws.textAll("WRONG:" + testWords[targetWordIndex]);
        }
      }
    }
  }
}


void setup() {
  Serial.begin(115200);
  randomSeed(analogRead(0));
 
  pinMode(buttonLearnPin, INPUT_PULLUP);
  pinMode(buttonGamePin, INPUT_PULLUP);
  pinMode(buttonScanPin, INPUT_PULLUP);
  pinMode(buttonDownloadPin, INPUT_PULLUP);


  // --- INITIALIZE LEDS ---
  pinMode(scanLed1, OUTPUT);
  pinMode(scanLed2, OUTPUT);
  digitalWrite(scanLed1, LOW);
  digitalWrite(scanLed2, LOW);


  // --- INITIALIZE PCA9685 SERVO DRIVER ---
  pwm.begin();
  pwm.setPWMFreq(50);
  clearBrailleSmooth();


  // --- CONNECT TO WIFI ---
  WiFi.begin("Nozaki-kun 2.4G", "Phoebe  Hunter  Kim");
  Serial.print("Connecting to Nozaki-kun 2.4G");
  while (WiFi.status() != WL_CONNECTED) {
    delay(500);
    Serial.print(".");
  }
  Serial.println("\nWiFi connected!");


  // --- START mDNS RESPONDER ---
  if (!MDNS.begin("brailleui")) {
    Serial.println("Error setting up MDNS responder!");
  } else {
    Serial.println("mDNS responder started.");
    Serial.println("Web UI is now ALWAYS available at: http://brailleui.local");
  }


  ws.onEvent(onEvent);
  server.addHandler(&ws);
  server.on("/", HTTP_GET, [](AsyncWebServerRequest *request){
    request->send_P(200, "text/html", index_html);
  });
  server.begin();
}


void loop() {
  ws.cleanupClients();


  bool readingLearn = digitalRead(buttonLearnPin);
  bool readingGame = digitalRead(buttonGamePin);
  bool readingScan = digitalRead(buttonScanPin);
  bool readingDownload = digitalRead(buttonDownloadPin);


  if (readingLearn == LOW && lastLearnState == HIGH) {
    activateMode(1);
    delay(250);
  }
  if (readingGame == LOW && lastGameState == HIGH) {
    activateMode(2);
    delay(250);
  }
 
  if (readingScan == LOW && lastScanState == HIGH) {
    if (activeMode != 3) {
        activateMode(3);
    } else {
        ws.textAll("TRIGGER_SCAN");
    }
    delay(250);
  }
 
  if (readingDownload == LOW && lastDownloadState == HIGH) {
    ws.textAll("DOWNLOAD_CSV");
    delay(250);
  }


  lastLearnState = readingLearn;
  lastGameState = readingGame;
  lastScanState = readingScan;
  lastDownloadState = readingDownload;


  if (activeMode == 1) {
    if (alphabetIndex <= 25) {
      char currentLetter = 'A' + alphabetIndex;
     
      if (learnStateStep == -1) {
        if (millis() - lastLetterTime >= 3000) {
          learnStateStep = 0;
        }
      }
      else if (learnStateStep == 0) {
        ws.textAll("SAY:" + String(currentLetter));
        Serial.println("Letter: " + String(currentLetter));
       
        displayBrailleLetterSmooth(alphabetIndex);
       
        lastLetterTime = millis();
        learnStateStep = 1;
      }
      else if (learnStateStep == 1) {
        if (millis() - lastLetterTime >= 3000) {
          ws.textAll("SAY:" + String(currentLetter));
         
          lastLetterTime = millis();
          learnStateStep = 2;
        }
      }
      else if (learnStateStep == 2) {
        if (millis() - lastLetterTime >= 3000) {
          alphabetIndex++;
          learnStateStep = 0;
        }
      }
    }
    else {
      // --- NEW SMART DELAY FOR THE ENDING ---
      if (learnStateStep == 0) {
        ws.textAll("SAY:Alphabet complete");
        Serial.println("--- ALPHABET COMPLETE ---");
        clearBrailleSmooth();
       
        lastLetterTime = millis();
        learnStateStep = 1;        
      }
      else if (learnStateStep == 1) {
        if (millis() - lastLetterTime >= 3000) {
          activateMode(0);
        }
      }
    }
  }


  if (activeMode == 2 && gameStarting) {
    if (millis() - gameInitTime >= 3000) {
      gameStarting = false;
      gameStartTime = millis();
      startNewGame();
    }
  }


  delay(10);
}

