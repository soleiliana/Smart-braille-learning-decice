// =========================================================
// --- SHUFFLE FUNCTION (NO REPEATS!) ---
// =========================================================
void shuffleWords() {
  // 1. Fill the array in order (0 to 29)
  for (int i = 0; i < 30; i++) {
    shuffledIndices[i] = i;
  }
  // 2. Fisher-Yates Shuffle algorithm
  for (int i = 29; i > 0; i--) {
    int j = random(0, i + 1); // Pick a random index from 0 to i
    // Swap the elements
    int temp = shuffledIndices[i];
    shuffledIndices[i] = shuffledIndices[j];
    shuffledIndices[j] = temp;
  }
}


// --- GAME MODE LOGIC ---
void startNewGame() {
  if (wordsServed >= totalRounds) {
    float duration = (millis() - gameStartTime) / 1000.0;
    float wpm = (totalRounds / (duration / 60.0));
    ws.textAll("RESULTS:" + String(duration, 1) + ":" + String(wpm, 1));
    wordsServed = 0;
    return;
  }
 
  // Draw from the shuffled deck instead of a random roll
  targetWordIndex = shuffledIndices[wordsServed];
 
  ws.textAll("SAY:" + testWords[targetWordIndex]);
  wordsServed++;
}


// =========================================================
// --- SMOOTH SERVO CONTROL LOGIC ---
// =========================================================


void transitionServosTo(int targetPos[6]) {
  bool isMoving = true;
 
  while (isMoving) {
    isMoving = false;
   
    for (int i = 0; i < 6; i++) {
      if (currentPos[i] < targetPos[i]) {
        currentPos[i] += 2;
        isMoving = true;
      }
      else if (currentPos[i] > targetPos[i]) {
        currentPos[i] -= 2;
        isMoving = true;
      }


      if (abs(currentPos[i] - targetPos[i]) < 2) {
        currentPos[i] = targetPos[i];
      }


      pwm.setPWM(dots[i], 0, currentPos[i]);
    }
   
    delay(4);
  }
}


void displayBrailleLetterSmooth(int letterIndex) {
  int targetPos[6];
  for (int i = 0; i < 6; i++) {
    targetPos[i] = braille[letterIndex][i] ? UP_POS : DOWN_POS;
  }
  transitionServosTo(targetPos);
}


void clearBrailleSmooth() {
  int targetPos[6] = {DOWN_POS, DOWN_POS, DOWN_POS, DOWN_POS, DOWN_POS, DOWN_POS};
  transitionServosTo(targetPos);
}


