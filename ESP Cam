// --- BASE64 ENCODER (Uses PSRAM to prevent memory crashes) ---
String base64Encode(uint8_t *buffer, size_t length) {
  size_t outputLength;
  mbedtls_base64_encode(NULL, 0, &outputLength, buffer, length);
  unsigned char *base64_buf = (unsigned char *)ps_malloc(outputLength + 1);
  if (!base64_buf) return "";
  mbedtls_base64_encode(base64_buf, outputLength, &outputLength, buffer, length);
  base64_buf[outputLength] = '\0';
  String result = String((char *)base64_buf);
  free(base64_buf);
  return result;
}




// --- 1. ML API SCAN HANDLER (/scan_now) ---
static esp_err_t scan_handler(httpd_req_t *req) {
  httpd_resp_set_hdr(req, "Access-Control-Allow-Origin", "*");




  camera_fb_t * fb = esp_camera_fb_get();
  if (!fb) {
    httpd_resp_send_500(req);
    return ESP_FAIL;
  }




  String base64Image = base64Encode(fb->buf, fb->len);
  esp_camera_fb_return(fb);




  if (base64Image == "") {
    httpd_resp_sendstr(req, "MEMORY ERROR");
    return ESP_OK;
  }




  WiFiClientSecure client;
  client.setInsecure();
 
  HTTPClient http;
  http.begin(client, pipedream_url);
  http.addHeader("Content-Type", "application/json");




  // Give Pipedream 20 seconds to run the ML model
  http.setTimeout(20000);
 
  String payload = "{\"bodyRaw64\":\"" + base64Image + "\"}";
  int httpResponseCode = http.POST(payload);
  String finalWord = "API ERROR";




  if (httpResponseCode > 0) {
    String response = http.getString();
   
    DynamicJsonDocument doc(8192);
    DeserializationError error = deserializeJson(doc, response);
   
    if (!error) {
      JsonArray predictions = doc["predictions"];
      std::vector<BrailleLetter> letters;




      for (JsonObject pred : predictions) {
        BrailleLetter bl;
        bl.x = pred["x"].as<float>();
        bl.y = pred["y"].as<float>();
        bl.class_label = pred["class"].as<String>();
        letters.push_back(bl);
      }




      // --- DYNAMIC 2D SORTING BASED ON CAMERA ORIENTATION ---
      std::sort(letters.begin(), letters.end(), [](const BrailleLetter& a, const BrailleLetter& b) {
        if (CAMERA_IS_SIDEWAYS) {
          // Camera is sideways: Line breaks are on the X axis, letters flow top-to-bottom
          if (abs(a.x - b.x) > 30.0) return a.x < b.x;
          return a.y < b.y;
        } else {
          // Standard view: Line breaks are on the Y axis, letters flow left-to-right
          if (abs(a.y - b.y) > 30.0) return a.y < b.y;
          return a.x < b.x;
        }
      });




      finalWord = "";
      for (auto bl : letters) {
        finalWord += bl.class_label;
      }
     
      if(finalWord == "") finalWord = "NO BRAILLE DETECTED";
    } else {
      finalWord = "JSON PARSE ERROR";
    }
  } else {
    Serial.print("HTTP POST Failed, Error Code: ");
    Serial.println(httpResponseCode);
  }
 
  http.end();
  httpd_resp_sendstr(req, finalWord.c_str());
  return ESP_OK;
}




// --- 2. MJPEG STREAM HANDLER (/capture) ---
#define PART_BOUNDARY "123456789000000000000987654321"
static const char* _STREAM_CONTENT_TYPE = "multipart/x-mixed-replace;boundary=" PART_BOUNDARY;
static const char* _STREAM_BOUNDARY = "\r\n--" PART_BOUNDARY "\r\n";
static const char* _STREAM_PART = "Content-Type: image/jpeg\r\nContent-Length: %u\r\n\r\n";




static esp_err_t capture_handler(httpd_req_t *req) {
  camera_fb_t * fb = NULL;
  esp_err_t res = ESP_OK;
  char * part_buf[64];




  httpd_resp_set_hdr(req, "Access-Control-Allow-Origin", "*");
  res = httpd_resp_set_type(req, _STREAM_CONTENT_TYPE);
  if (res != ESP_OK) { return res; }




  while (true) {
    fb = esp_camera_fb_get();
    if (!fb) { res = ESP_FAIL; break; }




    res = httpd_resp_send_chunk(req, _STREAM_BOUNDARY, strlen(_STREAM_BOUNDARY));
    if (res == ESP_OK) {
      size_t hlen = snprintf((char *)part_buf, 64, _STREAM_PART, fb->len);
      res = httpd_resp_send_chunk(req, (const char *)part_buf, hlen);
    }
    if (res == ESP_OK) {
      res = httpd_resp_send_chunk(req, (const char *)fb->buf, fb->len);
    }
    esp_camera_fb_return(fb);
    if (res != ESP_OK) break;
  }
  return res;
}




// --- Start Camera Web Server ---
void startCameraServer() {
  httpd_config_t config = HTTPD_DEFAULT_CONFIG();
  config.server_port = 81;
  config.stack_size = 16384;




  httpd_uri_t capture_uri = { .uri = "/capture", .method = HTTP_GET, .handler = capture_handler, .user_ctx = NULL };
  httpd_uri_t scan_uri = { .uri = "/scan_now", .method = HTTP_GET, .handler = scan_handler, .user_ctx = NULL };




  if (httpd_start(&stream_httpd, &config) == ESP_OK) {
    httpd_register_uri_handler(stream_httpd, &capture_uri);
    httpd_register_uri_handler(stream_httpd, &scan_uri);
    Serial.println("Camera Stream & API Server Started on Port 81");
  }
}




